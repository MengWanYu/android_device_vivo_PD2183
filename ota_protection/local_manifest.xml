<?xml version="1.0" encoding="UTF-8"?>
<manifest>
  <!-- Override bootable/recovery with OTA-protection fork -->
  <!-- Note: twrp-default.xml already removes platform/bootable/recovery and adds android_bootable_recovery.
       We override android_bootable_recovery (not platform/bootable/recovery). -->
  <remove-project name="android_bootable_recovery" />
  <project name="MengWanYu/android_bootable_recovery"
          path="bootable/recovery"
          remote="github"
          revision="android-12.1" />
</manifest>
